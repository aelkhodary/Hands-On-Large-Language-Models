# =============================================
# 📦 Step 0: Import required libraries
# =============================================
from datasets import load_dataset
from setfit import SetFitModel, SetFitTrainer, TrainingArguments
from sklearn.metrics import accuracy_score


# =============================================
# 📚 Step 1: Load dataset and simulate few-shot setting
# =============================================
# Load SST2 (Stanford Sentiment Treebank v2) - a binary sentiment dataset
dataset = load_dataset("sst2")

# Simulate few-shot: take only 16 training examples (8 per class)
# stratify_by_column ensures class balance
train_data = dataset["train"].train_test_split(train_size=16, stratify_by_column="label")["train"]
test_data = dataset["validation"]

# Sample structure of the dataset:
# train_data = [{"text": "I love this movie", "label": 1}, {"text": "Terrible film", "label": 0}, ...]


# =============================================
# 🤖 Step 2: Load pretrained SentenceTransformer model
# =============================================
# This model will be fine-tuned with contrastive learning
model = SetFitModel.from_pretrained("sentence-transformers/all-mpnet-base-v2")


# =============================================
# ⚙️ Step 3: Define training arguments
# =============================================
# Configuration for contrastive learning phase
args = TrainingArguments(
    num_epochs=3,           # Number of epochs for contrastive fine-tuning
    batch_size=4,           # Batch size during contrastive training
    evaluation_strategy="epoch"  # Evaluate after each epoch
)


# =============================================
# 🏋️ Step 4: Fine-tune using SetFitTrainer
# =============================================
# This will:
# - Generate positive/negative pairs
# - Fine-tune embeddings
# - Train a classifier on top of embeddings
trainer = SetFitTrainer(
    model=model,
    args=args,
    train_dataset=train_data,
    eval_dataset=test_data,
    metric=accuracy_score,
)

# Start training
trainer.train()


# =============================================
# 📊 Step 5: Evaluate model performance
# =============================================
metrics = trainer.evaluate()
print(f"Accuracy on test set: {metrics['accuracy']:.2f}")


# =============================================
# 🔮 Step 6: Predict on new/unseen text (inference)
# =============================================
preds = model.predict([
    "I really enjoyed this movie!",
    "This film was a disaster...",
    "Absolutely loved the performance.",
    "I wouldn't watch it again."
])
print(f"Predictions: {preds}")  # Expected: [1, 0, 1, 0] → [positive, negative, positive, negative]
